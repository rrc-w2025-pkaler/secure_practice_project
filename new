import logging 

data = []
new_data = []

HIGH_SALARY = 120000
RECOMMENDED_INCREASE = 0.20

logging.basicConfig(level = logging.DEBUG, filename = "app.log",
                    filemode = "w", format = "%(asctime)s - %(levelname)s - %(message)s")
#LECTURE SECTION 1

# Inititalize File to None (null) outside of try so that it is accessible in try and finally blocks.
file = None
try:
      file = open('module_4_data.txt')
      data = file.readlines()
      2/0

      file.close()
      print("File Closed")
except FileNotFoundError as e:
     # print("File does not exist", e)
     logging.error("File does not exist.")
except Exception as e:
      #print("General exceptions has occured", e)
      logging.error(e)
finally:
      if file is not None: 
            file.close()
          #  print("File Closed")
            logging.info("File closed")     

#LECTURE SECTION 2
try:
      if len(data) == 0:
            raise Exception("No data exists.")
      for record in data:
            items = record.split(',')
            title = items[0]
            name = items[1]
            salary = float(items[2])
            
            #LECTURE SECTION 3
            if salary > HIGH_SALARY:
                  logging.warning(f"{name},s salary {salary} is currently above the recommend maximum {HIGH_SALARY}.")
                  salary * (1 + RECOMMENDED_INCREASE) > HIGH_SALARY
                  logging.warning(f"{name},s salary {salary} will be above the recommended maximum of {HIGH_SALARY} with the planned {RECOMMENDED_INCREASE}")


            #REQUIREMENT:  NOTE RECORDS THAT EXCEED OR WILL EXCEED HIGH_SALARY AMOUNT
            salary *= (1 + RECOMMENDED_INCREASE)
            new_data.append([title,name,salary])
except Exception as e:
      #print(e)
      logging.error("Exception processing dta.")


#LECTURE SECTION 4
try:
      file = open('updated_salaries.txt', 'w')
      for record in new_data:
            row = ""
            for index, item in enumerate(record):
                  row += str(item)
                  if index < len(record) - 1:
                        row += (",")
            row += '\n'
            file.write(row)
except:
      #print("Exception writing data.")
      logging.error("Exception writing data.")
finally: 
      file.write("END OF FILE") 
      file.close()                 

